# Database
DATABASE_URL=mysql://root:password@localhost:3306/amazon_optimizer
# SQLite Database Path (Optional, for persisting data outside the project directory on a VPS)
# DB_PATH=/var/lib/optimus/optimus.db
QDRANT_URL=http://localhost:6333

# OpenAI (for embeddings)
OPENAI_API_KEY=sk-your-openai-api-key

# Paddle (payments)
PADDLE_API_KEY=your-paddle-api-key
PADDLE_WEBHOOK_SECRET=your-paddle-webhook-secret
PADDLE_ENVIRONMENT=sandbox

# Amazon SP-API
AMAZON_CLIENT_ID=your-amazon-client-id
AMAZON_CLIENT_SECRET=your-amazon-client-secret
AMAZON_APP_ID=amzn1.sp.solution.xxx

# JWT
JWT_SECRET=your-super-secret-jwt-key-min-32-chars

# Kimi OAuth
VITE_KIMI_AUTH_URL=https://auth.yourdomain.com
VITE_APP_ID=your-kimi-app-id
VITE_KIMI_AUTH_CLIENT_ID=your-kimi-client-id
KIMI_AUTH_CLIENT_SECRET=your-kimi-client-secret

# Application
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000
APP_VERSION=1.0.0

# Sentry Monitoring
SENTRY_DSN=https://xxx@yyy.ingest.sentry.io/zzz
SENTRY_AUTH_TOKEN=sntrys_your_auth_token
VITE_SENTRY_DSN=${SENTRY_DSN}
VITE_APP_VERSION=${APP_VERSION}
